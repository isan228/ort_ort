NODE_ENV=development
PORT=3001

# PostgreSQL (локально, без Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ort_kg
DB_USER=postgres
DB_PASSWORD=postgres

# Sequelize sync: true в dev, false в production
DB_SYNC_ALTER=true

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Asia/Bishkek
TZ=Asia/Bishkek

# CORS — URL фронтенда
CLIENT_URL=http://localhost:5173

# Платежи: stub (dev) | finik (production)
PAYMENT_PROVIDER=stub

# Finik Acquiring (https://www.finik.kg)
# FINIK_API_KEY=your-web-api-key
# FINIK_ACCOUNT_ID=your-corporate-account-id
# FINIK_QR_NAME_EN=ort-kg-premium
# FINIK_BASE_URL=https://api.acquiring.averspay.kg
# beta: https://beta.api.acquiring.averspay.kg
# Ключи по умолчанию читаются из корня репозитория:
#   finik_private.pem  (или private.pem)
#   finik_public.pem     (или public.pem)
# FINIK_PRIVATE_KEY_PATH=/custom/path/private.pem
# FINIK_PUBLIC_KEY_PATH=/custom/path/public.pem
# FINIK_WEBHOOK_PATH=/api/v1/payments/finik/webhook

# Секрет для legacy POST /api/v1/payments/callback (stub)
PAYMENT_CALLBACK_SECRET=dev-callback-secret
