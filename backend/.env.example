NODE_ENV=development
PORT=3001

# PostgreSQL (локально, без Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ort_kg
DB_USER=postgres
DB_PASSWORD=postgres

# Sequelize sync: true в dev, false в production
DB_SYNC_ALTER=true

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Asia/Bishkek
TZ=Asia/Bishkek

# CORS — URL фронтенда
CLIENT_URL=http://localhost:5173

# Секрет для POST /api/v1/payments/callback (заголовок X-Payment-Secret)
PAYMENT_CALLBACK_SECRET=dev-callback-secret
